<main class="min-h-screen bg-violet-950 text-white">
    <section class="mx-auto max-w-6xl px-4 py-8 sm:px-8">
        <header
            class="mb-6 flex items-center justify-between rounded-2xl border border-violet-800/70 bg-violet-900/50 px-4 py-3">
            <p class="text-sm font-semibold tracking-wide">Spnt</p>
            <button routerLink="/profile/{{userId}}"
                class="rounded-full border border-violet-600 px-4 py-2 text-xs text-violet-200 hover:bg-violet-800/70">Profile</button>
        </header>

        <section class="grid gap-4 lg:grid-cols-3">
            <div class="rounded-3xl border border-violet-700/80 bg-violet-900/60 p-6">
                <p class="text-xs text-violet-300">Overview</p>
                <p class="mt-8 text-lg font-semibold">{{ getTotalSpent() }}</p>
            </div>
            <div class="rounded-3xl border border-violet-700/80 bg-violet-900/60 p-6">
                <p class="text-xs text-violet-300">Overview</p>
                <p class="mt-8 text-lg font-semibold">{{ getSpentThisMonth() }}</p>
            </div>
            <div class="rounded-3xl border border-violet-700/80 bg-violet-900/60 p-6">
                <p class="text-xs text-violet-300">Overview</p>
                <p class="mt-8 text-lg font-semibold">Category wheel chart area</p>
            </div>
        </section>

        <section class="mt-6">
            <button type="button"
                class="rounded-xl border border-violet-400 bg-violet-400/20 px-6 py-2 font-semibold text-violet-100 hover:bg-violet-400/30"
                (click)="toggleCreatePanel()">
                + New
            </button>

            @if (showCreatePanel()) {
            <div class="mt-4 rounded-2xl border border-violet-700/80 bg-violet-900/60 p-3 sm:p-4 overflow-hidden transition-[max-height,opacity] duration-300 ease-in-out space-y-2">
                <div class="grid gap-3 sm:grid-cols-4">
                    <input #newTitle type="text" placeholder="Title"
                        class="rounded-xl border border-violet-700 bg-violet-950/80 px-3 py-2 text-sm placeholder:text-violet-400 focus:border-violet-400 focus:outline-none">
                    <input #newMoney type="number" placeholder="Money"
                        class="rounded-xl border border-violet-700 bg-violet-950/80 px-3 py-2 text-sm placeholder:text-violet-400 focus:border-violet-400 focus:outline-none">
                    <input #newCategory type="text" placeholder="Category"
                        class="rounded-xl border border-violet-700 bg-violet-950/80 px-3 py-2 text-sm placeholder:text-violet-400 focus:border-violet-400 focus:outline-none">
                    <input #newDate type="date" placeholder="Date"
                        class="rounded-xl border border-violet-700 bg-violet-950/80 px-3 py-2 text-sm placeholder:text-violet-400 focus:border-violet-400 focus:outline-none">
                </div>
                <textarea #newDesc rows="3" placeholder="Description"
                    class="mt-3 w-full rounded-xl border border-violet-700 bg-violet-950/80 px-3 py-2 text-sm placeholder:text-violet-400 focus:border-violet-400 focus:outline-none"></textarea>
                <div class="mt-3 flex items-center gap-2">
                    <button type="button"
                        class="rounded-lg border border-violet-500 px-4 py-2 text-sm font-semibold hover:bg-violet-500/20"
                        (click)="createNew(newTitle.value, newDesc.value, newMoney.valueAsNumber, newCategory.value, newDate.value)">
                        Save
                    </button>
                    <button type="button" class="rounded-lg border border-violet-700 px-4 py-2 text-sm text-violet-200"
                        (click)="toggleCreatePanel()">Close</button>
                </div>
            </div>
            }
        </section>

        <section class="mt-8 rounded-2xl border border-violet-800/70 bg-violet-900/50 p-4">
            @if (isLoading()) {
            <p class="rounded-lg border border-violet-700 bg-violet-950/70 px-3 py-2 text-sm text-violet-300">Loading...
            </p>
            } @else {
            @if (monthSections().length) {
            <div ngAccordionGroup class="space-y-4 basic-accordion">
                @for (section of monthSections(); track section.key) {
                <section class="rounded-xl border border-violet-700/70 p-3">
                    <button ngAccordionTrigger [panelId]="section.key" #trigger1="ngAccordionTrigger" [expanded]="true" class="px-3 w-full flex justify-between outline-none box-shadow-none">
                        <button>
                            {{ section.label }}
                        </button>
                        <button class="ml-2 inline-block place-self-end">
                            @if (trigger1.expanded()) {
                            <span class="h-3 w-3 fa">&blacktriangle;</span>
                            } @else {
                            <span class="h-3 w-3 fa">&blacktriangledown;</span>
                            }
                        </button>
                    </button>
                    <p class="mb-3 text-sm font-semibold text-violet-200"></p>
                    <div ngAccordionPanel [panelId]="section.key">
                        <div class="overflow-hidden transition-[max-height,opacity] duration-300 ease-in-out space-y-2"
                            [class.max-h-0]="!trigger1.expanded()" [class.opacity-0]="!trigger1.expanded()"
                            [class.pointer-events-none]="!trigger1.expanded()" [class.max-h-[1200px]]="trigger1.expanded()"
                            [class.opacity-100]="trigger1.expanded()">
                            @for (data of section.items; track data._id) {
                            <div
                                class="grid grid-cols-1 gap-2 rounded-xl border border-violet-700/80 bg-violet-950/60 p-2">
                                <input #date type="text" [value]="(data.date | date:'d MMMM yyyy') ?? ''"
                                    class="rounded-lg border border-violet-700 bg-violet-900/40 px-3 py-2 text-sm focus:border-violet-400 focus:outline-none">
                                <input #title type="text" [value]="data.title"
                                    class="rounded-lg border border-violet-700 bg-violet-900/40 px-3 py-2 text-sm focus:border-violet-400 focus:outline-none">
                                <input #money type="number" [value]="data.money || 0"
                                    class="rounded-lg border border-violet-700 bg-violet-900/40 px-3 py-2 text-sm focus:border-violet-400 focus:outline-none">
                                <input #category type="text" [value]="data.category"
                                    class="rounded-lg border border-violet-700 bg-violet-900/40 px-3 py-2 text-sm focus:border-violet-400 focus:outline-none">
                                <input #desc type="text" [value]="data.description || ''"
                                    class="rounded-lg border border-violet-700 bg-violet-900/40 px-3 py-2 text-sm focus:border-violet-400 focus:outline-none">
                                <button type="button"
                                    class="rounded-lg border border-violet-500 px-3 py-2 text-xs font-semibold hover:bg-violet-500/15"
                                    (click)="editItem(data._id, title.value, desc.value, money.valueAsNumber, category.value)">&</button>
                                <button type="button"
                                    class="rounded-lg border border-red-400/70 px-3 py-2 hover:bg-red-500/10"
                                    (click)="deleteItem(data._id)">
                                    <img src="/bin.png" alt="bin_icon"
                                        class="h-3 w-3 text-red-400/70 hover:text-red-500/10">
                                </button>
                            </div>
                            }
                        </div>
                    </div>
                </section>
                }
            </div>

            @if (visibleEntries().length < dataList().length) { <div class="mt-4 text-right">
                <button type="button" class="text-sm text-violet-300 underline underline-offset-4 hover:text-white"
                    (click)="showMore()">See more</button>
                </div>
                }
                } @else {
                <p class="rounded-lg border border-violet-700 bg-violet-950/70 px-3 py-2 text-sm text-violet-300">No
                    entries yet.</p>
                }
                }
        </section>
    </section>
</main>