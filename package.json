{
  "name": "spnt",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "server": "cd server && npm start",
    "serve:ssr:Spnt": "node dist/Spnt/server/server.mjs"
